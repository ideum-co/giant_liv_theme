<?php
/** @var $block \Magento\Catalog\Block\Product\AbstractProduct */

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$reviewEnabled = $objectManager->get(\Magento\Framework\App\Config\ScopeConfigInterface::class)
    ->getValue('catalog/review/active', \Magento\Store\Model\ScopeInterface::SCOPE_STORE);

if (!$reviewEnabled) {
    return;
}

$product = $block->getProduct();

if ($product->getRatingSummary() === null) {
    $appendSummary = $objectManager->get(\Magento\Review\Model\AppendSummaryDataFactory::class)->create();
    $storeId = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class)->getStore()->getId();
    $appendSummary->execute($product, $storeId, \Magento\Review\Model\Review::ENTITY_PRODUCT_CODE);
}

$reviewsCount = (int)$product->getReviewsCount();
$ratingSummary = (int)$product->getRatingSummary();
$filledStars = $ratingSummary ? round($ratingSummary / 20) : 0;

$productUrl = $product->getUrlModel()->getUrl($product, ['_ignore_category' => true]);
$urlReviews = $productUrl . '#reviews';
$urlForm = $productUrl . '#review-form';

$fullStar = '<svg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M2,0h16c1.1,0,2,0.9,2,2v16c0,1.1-0.9,2-2,2H2c-1.1,0-2-0.9-2-2V2C0,0.9,0.9,0,2,0z" fill="#06038D"/><path fill-rule="evenodd" clip-rule="evenodd" d="M10,13.5l-4.1,2.2l0.8-4.6L3.3,7.8l4.6-0.7L10,3l2.1,4.2l4.6,0.7l-3.3,3.2l0.8,4.6L10,13.5z" fill="#FFFFFF"/></svg>';

$emptyStar = '<svg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect fill="#DEDEDE" width="20" height="20" rx="2"/><path fill="#FFF" d="m10 13.5-4.114 2.163.785-4.581-3.328-3.245 4.6-.669L10 3l2.057 4.168 4.6.669-3.328 3.245.785 4.581z"/></svg>';
?>

<div class="product-reviews-summary<?= !$reviewsCount ? ' empty' : '' ?>">
    <div class="giant-review-summary">
        <div class="giant-review-stars">
            <?php for ($i = 1; $i <= 5; $i++): ?>
                <?= /* @noEscape */ ($i <= $filledStars) ? $fullStar : $emptyStar ?>
            <?php endfor; ?>
        </div>
        <div class="giant-review-text">
            <?php if ($reviewsCount): ?>
                <a href="<?= $block->escapeUrl($urlReviews) ?>"><?= (int)$reviewsCount ?> <?= $block->escapeHtml($reviewsCount == 1 ? __('reseña') : __('reseñas')) ?></a>
                <span class="giant-review-separator">/</span>
                <a href="<?= $block->escapeUrl($urlForm) ?>"><?= $block->escapeHtml(__('Escribe una reseña')) ?></a>
            <?php else: ?>
                <span><?= $block->escapeHtml(__('Sin reseñas')) ?></span>
                <span class="giant-review-separator">/</span>
                <a href="<?= $block->escapeUrl($urlForm) ?>"><?= $block->escapeHtml(__('Escribe la primera reseña')) ?></a>
            <?php endif; ?>
        </div>
    </div>
</div>
