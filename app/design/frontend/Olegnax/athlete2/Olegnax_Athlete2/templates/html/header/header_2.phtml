<script>
(function(){
    var imgs = document.querySelectorAll('.page-header .logo__container img.lazy, .page-header .top-bar img.lazy');
    for(var i=0;i<imgs.length;i++){
        var orig=imgs[i].getAttribute('data-original');
        if(orig){imgs[i].setAttribute('src',orig);imgs[i].classList.remove('lazy');}
    }

    var header = document.querySelector('.page-header');
    if (header) {
        var scrollThreshold = 50;
        var ticking = false;
        function onScroll() {
            if (!ticking) {
                window.requestAnimationFrame(function() {
                    if (window.scrollY > scrollThreshold) {
                        header.classList.add('giant-scrolled');
                    } else {
                        header.classList.remove('giant-scrolled');
                    }
                    ticking = false;
                });
                ticking = true;
            }
        }
        window.addEventListener('scroll', onScroll, {passive: true});
        onScroll();
    }

    var _gsc = function(){
        var wraps = document.querySelectorAll('.search_form_wrap');
        for(var w=0;w<wraps.length;w++){
            (function(wrap){
                var si = wrap.querySelector('input[type="text"]');
                var cb = wrap.querySelector('.giant-search-clear');
                if(!si||!cb) return;
                si.addEventListener('input', function(){
                    cb.style.display = si.value.length > 0 ? 'flex' : 'none';
                });
                si.addEventListener('focus', function(){
                    cb.style.display = si.value.length > 0 ? 'flex' : 'none';
                });
            })(wraps[w]);
        }
    };
    window._giantCloseSearch = function(){
        var hc=document.querySelector('.header__content.giant-search-open');
        if(hc){
            hc.classList.remove('giant-search-open');
            var fw=hc.querySelector('.giant-search-form-wrap');
            if(fw)fw.style.display='none';
        }
        document.body.classList.remove('giant-search-active');
    };
    document.addEventListener('keydown', function(e){
        if(e.key==='Escape') window._giantCloseSearch();
    });
    var _ov = document.createElement('div');
    _ov.className = 'giant-search-overlay';
    _ov.onclick = function(){ if(window._giantCloseSearch) window._giantCloseSearch(); };
    var pw = document.querySelector('.page-wrapper');
    if(pw) pw.insertBefore(_ov, pw.firstChild);

    if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',function(){setTimeout(_gsc,800);});}
    else{setTimeout(_gsc,800);}
})();
</script>
</div>