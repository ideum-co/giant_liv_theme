<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="giant_distributor" resource="default" engine="innodb" comment="Giant Distributors">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false"
                identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="Distributor Name"/>
        <column xsi:type="varchar" name="address" nullable="true" length="500"
                comment="Address"/>
        <column xsi:type="varchar" name="city" nullable="true" length="100"
                comment="City"/>
        <column xsi:type="varchar" name="department" nullable="true" length="100"
                comment="Colombian Department (Departamento)"/>
        <column xsi:type="varchar" name="phone" nullable="true" length="50"
                comment="Phone"/>
        <column xsi:type="varchar" name="email" nullable="true" length="150"
                comment="Email"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1"
                comment="Is Active (1=yes, 0=no)"/>
        <column xsi:type="int" name="sort_order" nullable="false" default="0"
                comment="Sort Order"/>
        <column xsi:type="varchar" name="store_ids" nullable="true" length="255"
                comment="Visible in Store IDs (comma-separated, empty = all)"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="GIANT_DISTRIBUTOR_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
        <index referenceId="GIANT_DISTRIBUTOR_SORT_ORDER" indexType="btree">
            <column name="sort_order"/>
        </index>
        <index referenceId="GIANT_DISTRIBUTOR_DEPARTMENT" indexType="btree">
            <column name="department"/>
        </index>
    </table>

</schema>
