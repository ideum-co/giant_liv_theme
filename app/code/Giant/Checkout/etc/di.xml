<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Bind repository interface to implementation -->
    <preference for="Giant\Checkout\Api\DistributorRepositoryInterface"
                type="Giant\Checkout\Model\DistributorRepository"/>

    <preference for="Giant\Checkout\Api\Data\DistributorInterface"
                type="Giant\Checkout\Model\Distributor"/>

    <!-- Register collection model for the UI grid data source -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="giant_distributor_listing_data_source"
                      xsi:type="string">Giant\Checkout\Model\ResourceModel\Distributor\Collection</item>
            </argument>
        </arguments>
    </type>

</config>
