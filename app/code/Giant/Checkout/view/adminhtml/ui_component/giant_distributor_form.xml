<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">giant_distributor_form.giant_distributor_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Información del Distribuidor</item>
        <item name="reverseMetadataMerge" xsi:type="boolean">true</item>
    </argument>

    <settings>
        <buttons>
            <button name="back">
                <url path="*/*/index"/>
                <class>back</class>
                <label translate="true">Volver</label>
            </button>
            <button name="delete">
                <deleteUrl path="*/*/delete"/>
                <class>delete</class>
                <label translate="true">Eliminar</label>
            </button>
            <button name="save_and_continue">
                <class>save</class>
                <label translate="true">Guardar y Continuar</label>
                <param name="back">edit</param>
            </button>
            <button name="save">
                <class>save primary</class>
                <label translate="true">Guardar Distribuidor</label>
            </button>
        </buttons>
        <namespace>giant_distributor_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>giant_distributor_form.giant_distributor_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="giant_distributor_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="Giant\Checkout\Ui\Component\Form\DataProvider\DistributorDataProvider"
                      name="giant_distributor_form_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Información General</label>
        </settings>

        <field name="entity_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>

        <field name="name" sortOrder="10" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Nombre del Distribuidor</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="address" sortOrder="20" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Dirección</label>
            </settings>
        </field>

        <field name="city" sortOrder="30" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Ciudad</label>
            </settings>
        </field>

        <field name="department" sortOrder="35" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Departamento</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Giant\Checkout\Model\Config\Source\Departments"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="phone" sortOrder="40" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Teléfono</label>
            </settings>
        </field>

        <field name="email" sortOrder="50" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Email</label>
                <validation>
                    <rule name="validate-email" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="is_active" sortOrder="60" formElement="select">
            <settings>
                <dataType>select</dataType>
                <label translate="true">Estado</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Enabledisable"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="sort_order" sortOrder="70" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Orden de visualización</label>
            </settings>
        </field>

        <field name="store_ids" sortOrder="80" formElement="multiselect">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Tiendas visibles</label>
                <tooltip>
                    <description translate="true">Deja vacío para mostrar en todas las tiendas.</description>
                </tooltip>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="Magento\Store\Ui\Component\Listing\Column\Store\Options"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>

    </fieldset>
</form>
