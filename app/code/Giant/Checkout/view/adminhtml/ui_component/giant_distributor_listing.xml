<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">giant_distributor_listing.giant_distributor_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Nuevo Distribuidor</label>
            </button>
        </buttons>
        <spinner>giant_distributor_columns</spinner>
        <deps>
            <dep>giant_distributor_listing.giant_distributor_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="giant_distributor_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Giant_Checkout::distributor</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="giant_distributor_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters">
            <settings>
                <templates>
                    <filters>
                        <select>
                            <param name="template" xsi:type="string">ui/grid/filters/elements/ui-select</param>
                            <param name="component" xsi:type="string">Magento_Ui/js/form/element/ui-select</param>
                        </select>
                    </filters>
                </templates>
            </settings>
        </filters>
        <massaction name="listing_massaction">
            <action name="enable">
                <settings>
                    <url path="*/*/massStatus">
                        <param name="status">1</param>
                    </url>
                    <type>enable</type>
                    <label translate="true">Habilitar</label>
                </settings>
            </action>
            <action name="disable">
                <settings>
                    <url path="*/*/massStatus">
                        <param name="status">0</param>
                    </url>
                    <type>disable</type>
                    <label translate="true">Deshabilitar</label>
                </settings>
            </action>
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">¿Eliminar los distribuidores seleccionados?</message>
                        <title translate="true">Eliminar distribuidores</title>
                    </confirm>
                    <url path="*/*/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Eliminar</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="giant_distributor_columns">
        <settings>
            <editorConfig>
                <param name="selectProvider" xsi:type="string">giant_distributor_listing.giant_distributor_listing.giant_distributor_columns.ids</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="indexField" xsi:type="string">entity_id</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">giant_distributor_listing.giant_distributor_listing.giant_distributor_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>

        <selectionsColumn name="ids">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Nombre</label>
            </settings>
        </column>

        <column name="city">
            <settings>
                <filter>text</filter>
                <label translate="true">Ciudad</label>
            </settings>
        </column>

        <column name="department">
            <settings>
                <filter>select</filter>
                <label translate="true">Departamento</label>
                <options class="Giant\Checkout\Model\Config\Source\Departments"/>
                <dataType>select</dataType>
            </settings>
        </column>

        <column name="phone">
            <settings>
                <label translate="true">Teléfono</label>
            </settings>
        </column>

        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Orden</label>
            </settings>
        </column>

        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Enabledisable"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Estado</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Giant\Checkout\Ui\Component\Listing\Column\DistributorActions">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
