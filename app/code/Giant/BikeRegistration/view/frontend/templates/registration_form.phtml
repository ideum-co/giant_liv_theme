<script>
document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('giant-registration-form');
    var successDiv = document.getElementById('giant-reg-success');

    document.querySelectorAll('.giant-reg-section-header').forEach(function(header) {
        header.addEventListener('click', function() {
            var step = parseInt(this.getAttribute('data-step'));
            toggleSection(step);
        });
    });

    document.querySelectorAll('.giant-reg-next').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var nextStep = parseInt(this.getAttribute('data-next'));
            var currentStep = nextStep - 1;
            if (validateSection(currentStep)) {
                openSection(nextStep);
            }
        });
    });

    document.querySelectorAll('.giant-reg-back').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var prevStep = parseInt(this.getAttribute('data-prev'));
            openSection(prevStep);
        });
    });

    var fileInput = document.getElementById('reg_invoice_file');
    if (fileInput) {
        fileInput.addEventListener('change', function() {
            var label = this.parentNode.querySelector('.giant-reg-file-label');
            label.textContent = this.files.length ? this.files[0].name : 'Seleccionar archivo...';
        });
    }

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!validateSection(3)) return;
        if (!document.getElementById('reg_terms').checked) {
            alert('Debe aceptar los términos y condiciones.');
            return;
        }

        var submitBtn = form.querySelector('.giant-reg-submit');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';

        var formData = new FormData(form);
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?= $this->escapeJs($formAction) ?>', true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        xhr.onload = function() {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Registrar Bicicleta';
            try {
                var response = JSON.parse(xhr.responseText);
                if (response.success) {
                    form.style.display = 'none';
                    document.querySelector('.giant-reg-intro').style.display = 'none';
                    successDiv.style.display = 'block';
                    document.getElementById('giant-reg-id').textContent = 'GCO-' + String(response.registration_id).padStart(6, '0');
                    document.getElementById('giant-reg-download').href = '<?= $this->escapeJs($downloadUrl) ?>?id=' + response.registration_id + '&token=' + response.download_token;
                    window.scrollTo({top: 0, behavior: 'smooth'});
                } else {
                    alert(response.message || 'Error al enviar el formulario.');
                }
            } catch(err) {
                alert('Error al procesar la respuesta del servidor.');
            }
        };

        xhr.onerror = function() {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Registrar Bicicleta';
            alert('Error de conexión. Intente nuevamente.');
        };

        xhr.send(formData);
    });

    function toggleSection(step) {
        var section = document.querySelector('[data-section="' + step + '"]');
        var body = section.querySelector('.giant-reg-section-body');
        var header = section.querySelector('.giant-reg-section-header');
        var isOpen = body.style.display !== 'none';
        if (isOpen) {
            body.style.display = 'none';
            header.classList.remove('active');
        } else {
            openSection(step);
        }
    }

    function openSection(step) {
        document.querySelectorAll('.giant-reg-section-body').forEach(function(b) { b.style.display = 'none'; });
        document.querySelectorAll('.giant-reg-section-header').forEach(function(h) { h.classList.remove('active'); });
        var section = document.querySelector('[data-section="' + step + '"]');
        section.querySelector('.giant-reg-section-body').style.display = 'block';
        section.querySelector('.giant-reg-section-header').classList.add('active');
        section.scrollIntoView({behavior: 'smooth', block: 'start'});
    }

    function validateSection(step) {
        var section = document.querySelector('[data-section="' + step + '"]');
        if (!section) return true;
        var inputs = section.querySelectorAll('[required]');
        var valid = true;
        inputs.forEach(function(input) {
            input.classList.remove('giant-reg-error');
            if (!input.value.trim()) {
                input.classList.add('giant-reg-error');
                valid = false;
            }
            if (input.type === 'email' && input.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
                input.classList.add('giant-reg-error');
                valid = false;
            }
        });
        if (!valid) {
            var firstError = section.querySelector('.giant-reg-error');
            if (firstError) firstError.focus();
        }
        return valid;
    }
});
</script>
