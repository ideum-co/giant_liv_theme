<script>
    function testConnection() {
        var btn = document.getElementById('btn-test');
        var statusArea = document.getElementById('status-area');
        var progressArea = document.getElementById('progress-area');

        btn.disabled = true;
        statusArea.innerHTML = '';
        document.getElementById('results-area').style.display = 'none';
        progressArea.className = 'sheetsync-progress active';
        document.getElementById('progress-text').textContent = 'Verificando conexiones...';

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?= $testUrl ?>');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                progressArea.className = 'sheetsync-progress';
                btn.disabled = false;
                try {
                    var resp = JSON.parse(xhr.responseText);
                    var html = '';
                    if (resp.checks) {
                        var labels = {
                            google_auth: 'Autenticación Google',
                            google_sheet: 'Lectura Google Sheet',
                            magento_db: 'Base de datos Magento'
                        };
                        for (var key in resp.checks) {
                            var c = resp.checks[key];
                            var cls = c.status === 'ok' ? 'ok' : 'error';
                            var icon = c.status === 'ok' ? '✓' : '✗';
                            html += '<div class="sheetsync-check ' + cls + '"><span class="icon">' + icon + '</span><strong>' + (labels[key] || key) + ':</strong>&nbsp;' + c.message + '</div>';
                        }
                    }
                    statusArea.innerHTML = html;
                } catch(e) {
                    statusArea.innerHTML = '<div class="sheetsync-check error"><span class="icon">✗</span>Error inesperado al probar conexiones</div>';
                }
            }
        };
        xhr.send('form_key=' + window.FORM_KEY);
    }

    function runSync() {
        var btn = document.getElementById('btn-sync');
        var btnTest = document.getElementById('btn-test');
        var statusArea = document.getElementById('status-area');
        var progressArea = document.getElementById('progress-area');
        var resultsArea = document.getElementById('results-area');

        btn.disabled = true;
        btnTest.disabled = true;
        statusArea.innerHTML = '';
        resultsArea.style.display = 'none';
        progressArea.className = 'sheetsync-progress active';
        document.getElementById('progress-text').textContent = 'Leyendo Google Sheet y actualizando productos en Magento... Esto puede tomar varios minutos.';

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?= $syncUrl ?>');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.timeout = 600000;
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                progressArea.className = 'sheetsync-progress';
                btn.disabled = false;
                btnTest.disabled = false;
                try {
                    var resp = JSON.parse(xhr.responseText);
                    if (resp.success && resp.data) {
                        var d = resp.data;
                        var html = '<h3>Resultados de la Sincronización</h3>';
                        html += '<div class="sheetsync-stats">';
                        html += '<div class="sheetsync-stat total"><span class="number">' + d.total + '</span><span class="label">Total Procesados</span></div>';
                        html += '<div class="sheetsync-stat updated"><span class="number">' + d.updated + '</span><span class="label">Actualizados</span></div>';
                        html += '<div class="sheetsync-stat notfound"><span class="number">' + d.not_found + '</span><span class="label">No Encontrados</span></div>';
                        html += '<div class="sheetsync-stat errors"><span class="number">' + d.errors + '</span><span class="label">Errores</span></div>';
                        html += '</div>';

                        statusArea.innerHTML = '<div class="sheetsync-check ok"><span class="icon">✓</span>' + resp.message + '</div>';

                        if (d.not_found > 0) {
                            statusArea.innerHTML += '<div class="sheetsync-check pending" style="background:#fff8e1;color:#856404"><span class="icon">⚠</span>' + d.not_found + ' SKUs no encontrados — escritos en la hoja "SKUs no encontrados" del Google Sheet</div>';
                        }

                        if (d.sample_updated && d.sample_updated.length > 0) {
                            html += '<details class="sheetsync-details"><summary>SKUs actualizados (muestra)</summary><ul>';
                            d.sample_updated.forEach(function(s) { html += '<li>' + s + '</li>'; });
                            html += '</ul></details>';
                        }
                        if (d.sample_not_found && d.sample_not_found.length > 0) {
                            html += '<details class="sheetsync-details"><summary>SKUs no encontrados (muestra)</summary><ul>';
                            d.sample_not_found.forEach(function(s) { html += '<li>' + s + '</li>'; });
                            html += '</ul></details>';
                        }
                        if (d.error_details && d.error_details.length > 0) {
                            html += '<details class="sheetsync-details"><summary>Detalles de errores</summary><ul>';
                            d.error_details.forEach(function(e) { html += '<li>' + e + '</li>'; });
                            html += '</ul></details>';
                        }

                        resultsArea.innerHTML = html;
                        resultsArea.style.display = 'block';
                    } else {
                        statusArea.innerHTML = '<div class="sheetsync-check error"><span class="icon">✗</span>' + (resp.message || 'Error desconocido') + '</div>';
                    }
                } catch(e) {
                    statusArea.innerHTML = '<div class="sheetsync-check error"><span class="icon">✗</span>Error inesperado: ' + e.message + '</div>';
                }
            }
        };
        xhr.send('form_key=' + window.FORM_KEY);
    }
</script>
