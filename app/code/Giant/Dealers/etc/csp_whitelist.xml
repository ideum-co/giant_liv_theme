<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="unpkg_leaflet" type="host">unpkg.com</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>
                <value id="unpkg_leaflet_css" type="host">unpkg.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="osm_tiles_a" type="host">*.tile.openstreetmap.org</value>
                <value id="unpkg_leaflet_img" type="host">unpkg.com</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="osm_tiles" type="host">*.tile.openstreetmap.org</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
