<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="giant_dealers" resource="default" engine="innodb" comment="Giant Dealers">
        <column xsi:type="int" name="dealer_id" unsigned="true" nullable="false" identity="true" comment="Dealer ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Dealer Name"/>
        <column xsi:type="varchar" name="logo" nullable="true" length="500" comment="Logo Image Path"/>
        <column xsi:type="varchar" name="city" nullable="false" length="255" comment="City"/>
        <column xsi:type="varchar" name="address" nullable="false" length="500" comment="Address"/>
        <column xsi:type="varchar" name="phones" nullable="true" length="255" comment="Phone Numbers"/>
        <column xsi:type="varchar" name="email" nullable="true" length="255" comment="Contact Email"/>
        <column xsi:type="decimal" name="latitude" scale="8" precision="11" nullable="true" comment="Latitude"/>
        <column xsi:type="decimal" name="longitude" scale="8" precision="11" nullable="true" comment="Longitude"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="dealer_id"/>
        </constraint>
        <index referenceId="GIANT_DEALERS_CITY" indexType="btree">
            <column name="city"/>
        </index>
        <index referenceId="GIANT_DEALERS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>
</schema>
