<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">giant_dealers_listing.giant_dealers_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Nuevo Distribuidor</label>
            </button>
        </buttons>
        <spinner>giant_dealers_columns</spinner>
        <deps>
            <dep>giant_dealers_listing.giant_dealers_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="giant_dealers_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="giant_dealers_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>dealer_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="giant_dealers_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>dealer_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="dealer_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Nombre</label>
            </settings>
        </column>
        <column name="city">
            <settings>
                <filter>text</filter>
                <label translate="true">Ciudad</label>
            </settings>
        </column>
        <column name="address">
            <settings>
                <filter>text</filter>
                <label translate="true">Dirección</label>
            </settings>
        </column>
        <column name="phones">
            <settings>
                <filter>text</filter>
                <label translate="true">Teléfonos</label>
            </settings>
        </column>
        <column name="email">
            <settings>
                <filter>text</filter>
                <label translate="true">Email</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Activo</label>
                <dataType>select</dataType>
                <options>
                    <option name="1" xsi:type="array">
                        <item name="value" xsi:type="string">1</item>
                        <item name="label" xsi:type="string">Sí</item>
                    </option>
                    <option name="0" xsi:type="array">
                        <item name="value" xsi:type="string">0</item>
                        <item name="label" xsi:type="string">No</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Orden</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Giant\Dealers\Ui\Component\Listing\Column\DealerActions">
            <settings>
                <indexField>dealer_id</indexField>
                <label translate="true">Acciones</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
